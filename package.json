{
    "name": "timetable-service",
    "version": "1.0.0",
    "description": "Timetable Management microservice for Smart Campus Services - CTSE Assignment",
    "main": "src/app.js",
    "scripts": {
        "start": "node src/app.js",
        "dev": "nodemon src/app.js",
        "test": "jest --coverage --forceExit --detectOpenHandles",
        "test:watch": "jest --watch",
        "lint": "eslint src/ --ext .js",
        "lint:fix": "eslint src/ --ext .js --fix"
    },
    "keywords": [
        "microservice",
        "timetable",
        "schedule",
        "express"
    ],
    "author": "Student 3",
    "license": "MIT",
    "dependencies": {
        "axios": "^1.6.7",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.5",
        "helmet": "^7.1.0",
        "joi": "^17.12.1",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.1.1",
        "morgan": "^1.10.0",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.0"
    },
    "devDependencies": {
        "eslint": "^8.56.0",
        "jest": "^29.7.0",
        "mongodb-memory-server": "^9.1.6",
        "nodemon": "^3.0.3",
        "supertest": "^6.3.4"
    },
    "jest": {
        "testEnvironment": "node",
        "coverageDirectory": "coverage",
        "collectCoverageFrom": [
            "src/**/*.js",
            "!src/app.js"
        ]
    }
}